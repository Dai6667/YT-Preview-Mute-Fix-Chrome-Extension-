{
    "manifest_version":  3,
    "name":  "YT Preview Mute Fix",
    "version":  "0.1.0",
    "description":  "Force-mute YouTube hover/thumbnail preview videos (without affecting the main player).",
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://www.youtube.com/*",
                                                "https://m.youtube.com/*",
                                                "https://www.youtube-nocookie.com/*"
                                            ],
                                "js":  [
                                           "contentScript.js"
                                       ],
                                "run_at":  "document_start"
                            }
                        ],
    "icons":  {
                  "16":  "icons/icon16.png",
                  "128":  "icons/icon128.png",
                  "48":  "icons/icon48.png"
              },
    "action":  {
                   "default_title":  "YT Preview Mute Fix",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "128":  "icons/icon128.png",
                                        "48":  "icons/icon48.png"
                                    }
               },
    "homepage_url":  "https://github.com/Dai6667/YT-Preview-Mute-Fix-Chrome-Extension-"
}
